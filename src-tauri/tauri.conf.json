{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TuxMusic",
  "version": "0.0.1",
  "identifier": "git.tuxmusic.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "https://tuxmusic.vercel.app/desktop/",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tuxmusic-gui",
        "decorations": false,
        "width": 800,
        "height": 600,
        "transparent": true,
        "userAgent": "TuxMusic/0.0.1 (Official; Client; byLerman)"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}